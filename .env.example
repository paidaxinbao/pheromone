# Pheromone Hub v3 Configuration
# Copy this file to .env and customize as needed

# =============================================================================
# Hub Basic Configuration
# =============================================================================
MAILBOX_PORT=18888
MAILBOX_HOST=0.0.0.0

# =============================================================================
# Agent State Management
# =============================================================================
# Maximum concurrent messages per agent (default: 1)
AGENT_STATE_MAX_CONCURRENT=1

# Busy timeout in milliseconds (default: 300000 = 5 minutes)
AGENT_STATE_BUSY_TIMEOUT=300000

# Offline timeout in milliseconds (default: 90000 = 90 seconds)
AGENT_STATE_OFFLINE_TIMEOUT=90000

# =============================================================================
# Message Queue
# =============================================================================
# Maximum messages per agent queue (default: 50)
MESSAGE_QUEUE_MAX_SIZE=50

# Enable priority sorting (default: false)
MESSAGE_QUEUE_ENABLE_PRIORITY_SORT=false

# =============================================================================
# Message Scheduler
# =============================================================================
# Scheduler interval in milliseconds (default: 500)
SCHEDULER_INTERVAL=500

# Enable scheduler (default: true)
SCHEDULER_ENABLED=true

# Maximum delivery retries (default: 3)
SCHEDULER_MAX_DELIVERY_RETRIES=3

# =============================================================================
# Broadcast Filter
# =============================================================================
# Maximum recipients for broadcast (default: 4)
BROADCAST_MAX_RECIPIENTS=4

# Minimum recipients for broadcast (default: 2)
BROADCAST_MIN_RECIPIENTS=2

# Strategy: role-based, round-robin, random (default: role-based)
BROADCAST_STRATEGY=role-based

# Enable broadcast filter (default: true)
BROADCAST_ENABLED=true

# =============================================================================
# Conversation Manager (Protection Layer)
# =============================================================================
# Max messages in 5 minutes (default: 50)
CONVERSATION_MAX_MESSAGES_5MIN=50

# Max messages per minute (default: 10)
CONVERSATION_MAX_MESSAGES_1MIN=10

# Conversation expiration time in milliseconds (default: 1800000 = 30 minutes)
CONVERSATION_EXPIRATION_TIME=1800000

# Enable conversation manager (default: true)
CONVERSATION_ENABLED=true

# =============================================================================
# Cooldown Manager (Protection Layer)
# =============================================================================
# Cooldown period in milliseconds
# Temporary: 3000 (3 seconds) - allows normal conversation
# Long-term: consider soft-cooldown implementation
COOLDOWN_PERIOD=3000

# Apply cooldown to broadcast messages (default: false)
COOLDOWN_APPLY_TO_ALL=false

# Enable cooldown manager (default: true)
COOLDOWN_ENABLED=true

# =============================================================================
# Message Persistence
# =============================================================================
# Enable message persistence (default: true)
PERSIST_MESSAGES=true

# Message retention time in milliseconds (default: 3600000 = 1 hour)
MESSAGE_RETENTION=3600000

# =============================================================================
# Callback Dispatcher
# =============================================================================
# Callback timeout in milliseconds (default: 10000 = 10 seconds)
CALLBACK_TIMEOUT=10000

# Maximum retry attempts (default: 3)
CALLBACK_MAX_RETRIES=3

# =============================================================================
# Logging
# =============================================================================
# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Enable debug logging (default: false)
DEBUG=false
